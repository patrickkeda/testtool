{
  "commands": {
    "enfac": {
      "description": "工程模式管理",
      "parameter_count": 2,
      "parameters": [
        {
          "name": "op",
          "description": "操作类型",
          "required": true,
          "valid_values": ["0", "1"]
        },
        {
          "name": "en",
          "description": "工程模式状态 (0-退出, 1-进入)",
          "required": false,
          "valid_values": ["0", "1"]
        }
      ],
      "operation_mapping": {
        "0": "查询工程模式状态 (返回enfac或exfac)",
        "1": "写入工程模式 (en=1进入, en=0退出)"
      }
    },
    "action_mode": {
      "description": "进入模式",
      "parameter_count": 5,
      "parameters": [
        {
          "name": "op",
          "description": "操作类型",
          "required": true,
          "valid_values": ["0", "1", "2"]
        },
        {
          "name": "mode",
          "description": "模式名称",
          "required": false,
          "valid_values": ["burnin", "mtf", "mtb", "mtl", "mtr", "noise", "laydown", "stand", "stop", "mpc", "rl_stand", "navi", "restart"]
        },
        {
          "name": "sec",
          "description": "自动停止时间（秒），可选，超时后自动停止煲机",
          "required": false
        },
        {
          "name": "soc_min",
          "description": "电量最低阈值（0-100%），可选，电量低于该值后自动停止煲机",
          "required": false
        },
        {
          "name": "sleep",
          "description": "启动前休眠时间（秒），可选，休眠指定秒数后再开始运动",
          "required": false
        }
      ],
      "operation_mapping": {
        "0": "查询模式",
        "1": "启动模式，可附加 sec（超时停止）、soc_min（电量不足停止）、sleep（延迟启动）参数",
        "2": "关闭模式"
      }
    },
    "version": {
      "description": "获取版本信息",
